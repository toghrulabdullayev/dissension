# ---------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/dissension
DB_USERNAME=dissension
DB_PASSWORD=dissension

# ---------------------------------------------------------------
# Redis
# ---------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------
# JWT
# REQUIRED in production — must be a random string of at least 32 characters
# Generate with: openssl rand -base64 64
# ---------------------------------------------------------------
JWT_SECRET=replace-me-with-a-long-random-secret

# ---------------------------------------------------------------
# Google OAuth2
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google  (dev)
# ---------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------------
# DigitalOcean Spaces (S3-compatible object storage)
# For local dev you can use MinIO instead — see setup-guide.md
# ---------------------------------------------------------------
SPACES_ACCESS_KEY=your-spaces-access-key
SPACES_SECRET_KEY=your-spaces-secret-key
SPACES_BUCKET=dissension
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3

# ---------------------------------------------------------------
# coturn TURN server (used for WebRTC NAT traversal)
# For local dev, STUN-only works on the same network — TURN is needed for prod
# ---------------------------------------------------------------
TURN_HOST=turn.yourdomain.com
TURN_PORT=3478
TURN_USERNAME=dissension
TURN_CREDENTIAL=replace-me-with-turn-secret
