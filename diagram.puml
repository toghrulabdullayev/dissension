@startuml diagram
skinparam linetype polyline
skinparam ranksep 70
skinparam nodesep 40
skinparam classAttributeIconSize 0
top to bottom direction
hide methods

' Controllers
'!gen_java app.dissension.demo.auth.controller.AuthController
'!gen_java app.dissension.demo.channel.controller.ChannelController
'!gen_java app.dissension.demo.chat.controller.ChatController
'!gen_java app.dissension.demo.server.controller.ServerController

' Entities
'!gen_java app.dissension.demo.auth.entity.AppUser
'!gen_java app.dissension.demo.channel.entity.AppChannel
'!gen_java app.dissension.demo.chat.entity.ChatMessage
'!gen_java app.dissension.demo.server.entity.AppServer
'!gen_java app.dissension.demo.server.entity.ServerMembership

' Services
'!gen_java app.dissension.demo.auth.service.AuthService
'!gen_java app.dissension.demo.channel.service.ChannelPermissionService
'!gen_java app.dissension.demo.channel.service.ChannelService
'!gen_java app.dissension.demo.chat.service.AbstractChannelMessagePolicy
'!gen_java app.dissension.demo.chat.service.ChatChannelMessagePolicy
'!gen_java app.dissension.demo.chat.service.ChatMessageService
'!gen_java app.dissension.demo.chat.service.InfoChannelMessagePolicy
'!gen_java app.dissension.demo.chat.service.PresenceService
'!gen_java app.dissension.demo.server.service.ServerMembershipService
'!gen_java app.dissension.demo.server.service.ServerModerationService
'!gen_java app.dissension.demo.server.service.ServerService

' Entry point
'!gen_java app.dissension.demo.DemoApplication

' Domain-only relationships (entities + core services)
'
' Core service inheritance
ChatChannelMessagePolicy --|> AbstractChannelMessagePolicy
InfoChannelMessagePolicy --|> AbstractChannelMessagePolicy

' Controller to service
AuthController --> AuthService
ChannelController --> ChannelService
ChatController --> ChatMessageService
ServerController --> ServerService

' Entity associations
AppChannel "0..*" --> "1" AppServer : server
ChatMessage "0..*" --> "1" AppChannel : channel
ChatMessage "0..*" --> "1" AppUser : author
ServerMembership "0..*" --> "1" AppServer : server
ServerMembership "0..*" --> "1" AppUser : user

' Core service dependencies
ChannelService --> ServerMembershipService
ChannelService --> ChannelPermissionService
ChatMessageService --> ServerMembershipService
ChatMessageService --> AbstractChannelMessagePolicy
ServerModerationService --> ServerMembershipService
ServerService --> ServerMembershipService
ServerService --> ServerModerationService
ServerService --> PresenceService

' Hidden links help PlantUML distribute nodes in a balanced shape.
AuthController -[hidden]-> ChannelController
AuthController -[hidden]-> ChatController
ChatController -[hidden]-> ServerController

AuthService -[hidden]-> ChannelService
AuthService -[hidden]-> ChatMessageService
ChatMessageService -[hidden]-> ServerService

AppUser -[hidden]-> AppServer
AppUser -[hidden]-> AppChannel
AppChannel -[hidden]-> ChatMessage
AppUser -[hidden]-> ServerMembership

AuthController -[hidden]-> AuthService
ChannelController -[hidden]-> ChannelService
ChatController -[hidden]-> ChatMessageService
ServerController -[hidden]-> ServerService

AuthService -[hidden]-> AppUser
ChannelService -[hidden]-> AppChannel
ChatMessageService -[hidden]-> ChatMessage
ServerService -[hidden]-> AppServer

' Pull policy classes from far-right toward lower-left zone.
AbstractChannelMessagePolicy -[hidden]-> AppUser
ChatChannelMessagePolicy -[hidden]-> AppUser
InfoChannelMessagePolicy -[hidden]-> AppUser

@enduml