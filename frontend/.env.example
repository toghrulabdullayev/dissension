# ---------------------------------------------------------------
# Frontend — Vite environment variables
# Copy to frontend/.env.local for local development
# ---------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=http://localhost:8080/ws

# TURN server ICE config passed to the WebRTC peer connection (optional in dev)
VITE_TURN_HOST=turn.yourdomain.com
VITE_TURN_USERNAME=dissension
VITE_TURN_CREDENTIAL=replace-me-with-turn-secret
